generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ────────────────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  CLIENTE
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
}

enum EstadoMembresia {
  ACTIVA
  CANCELADA
  VENCIDA
}

// ── MODELOS ───────────────────────────────────────────────────────────────────

model Usuario {
  id         Int                @id @default(autoincrement())
  nombre     String
  email      String             @unique
  password   String
  telefono   String?
  rol        Rol                @default(CLIENTE)
  createdAt  DateTime           @default(now())
  citas      Cita[]
  membresias UsuarioMembresia[]
}

model Barbero {
  id           Int      @id @default(autoincrement())
  nombre       String
  especialidad String
  descripcion  String?
  foto         String?
  pin          String?
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  citas        Cita[]
}

model Servicio {
  id          Int            @id @default(autoincrement())
  nombre      String
  descripcion String?
  precio      Float
  duracion    Int
  imagen      String?
  activo      Boolean        @default(true)
  citas       CitaServicio[]
}

model EstiloCorte {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  imagen      String?
  categoria   String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Cita {
  id        Int            @id @default(autoincrement())
  fecha     DateTime
  hora      String
  estado    EstadoCita     @default(PENDIENTE)
  nota      String?
  createdAt DateTime       @default(now())

  usuarioId Int
  usuario   Usuario        @relation(fields: [usuarioId], references: [id])

  barberoId Int
  barbero   Barbero        @relation(fields: [barberoId], references: [id])

  servicios CitaServicio[]
}

model CitaServicio {
  citaId     Int
  servicioId Int
  cita       Cita     @relation(fields: [citaId], references: [id])
  servicio   Servicio @relation(fields: [servicioId], references: [id])

  @@id([citaId, servicioId])
}

model ImagenCarrusel {
  id          Int      @id @default(autoincrement())
  url         String
  nombre      String
  descripcion String?
  orden       Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Producto {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  precio      Float
  imagen      String?
  categoria   String?
  badge       String?
  stock       Int      @default(0)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Membresia {
  id              Int                @id @default(autoincrement())
  nombre          String
  precio          Float
  cortesIncluidos Int
  descripcion     String?
  beneficios      String?
  descuento       Int                @default(0)
  activo          Boolean            @default(true)
  createdAt       DateTime           @default(now())
  usuarios        UsuarioMembresia[]
}

model UsuarioMembresia {
  id           Int             @id @default(autoincrement())
  usuarioId    Int
  membresiaId  Int
  fechaInicio  DateTime        @default(now())
  fechaFin     DateTime
  cortesUsados Int             @default(0)
  estado       EstadoMembresia @default(ACTIVA)
  createdAt    DateTime        @default(now())
  usuario      Usuario         @relation(fields: [usuarioId], references: [id])
  membresia    Membresia       @relation(fields: [membresiaId], references: [id])
}
