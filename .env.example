# ── Base de datos ─────────────────────────────────────────────────────────────
# Cadena de conexión a PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/lafama_db"

# ── Autenticación ─────────────────────────────────────────────────────────────
# Clave secreta para firmar JWTs (mínimo 16 caracteres, usa un valor aleatorio)
JWT_SECRET="cambia_esto_por_un_secreto_seguro_min16"

# Clave secreta para las sesiones de Express
SESSION_SECRET="cambia_esto_por_otro_secreto_seguro_min16"

# ── Google OAuth 2.0 (opcional) ───────────────────────────────────────────────
# Obtén estas credenciales en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origen permitido para el frontend (sin barra final)
CORS_ORIGIN="http://localhost:5173"
